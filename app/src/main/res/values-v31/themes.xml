<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Android 12+ (API 31+) splash screen overrides.

        windowSplashScreenAnimatedIcon is set to a transparent drawable so Android
        does NOT draw its forced-circular icon container. The real ClassFlow icon
        (square with rounded corners) is shown by the SplashActivity layout instead.

        windowBackground carries @drawable/splash_screen so the icon is visible
        the instant the SplashActivity window appears (before setContentView finishes).
    -->
    <style name="Theme.ClassFlow.Splash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowSplashScreenBackground">@color/splash_bg</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_transparent</item>
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <item name="android:statusBarColor">@color/splash_bg</item>
        <item name="android:navigationBarColor">@color/splash_bg</item>
    </style>
</resources>
