<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon foreground. The adaptive icon canvas is 108dp × 108dp total.
    The safe zone (guaranteed visible on all launcher shapes) is the center 72dp × 72dp.
    18dp inset on each side centers the artwork within that safe zone.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:drawable="@drawable/ic_splash_logo"
        android:top="18dp"
        android:bottom="18dp"
        android:left="18dp"
        android:right="18dp" />
</layer-list>
