<navigation
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:id="@+id/nav_graph"
app:startDestination="@id/homeFragment" >
<fragment
    android:id="@+id/homeFragment"
    android:name="com.classflow.ui.home.HomeFragment"
    android:label="Home"
    tools:layout="@layout/fragment_home" >

    <action
        android:id="@+id/action_homeFragment_to_classListFragment"
        app:destination="@id/classListFragment" />
    <action
        android:id="@+id/action_homeFragment_to_taskDetailFragment"
        app:destination="@id/taskDetailFragment" />
    <action
        android:id="@+id/action_homeFragment_to_settingsFragment"
        app:destination="@id/settingsFragment" />
    <action
        android:id="@+id/action_homeFragment_to_searchTasksFragment"
        app:destination="@id/searchTasksFragment" />

</fragment>
<fragment
    android:id="@+id/classListFragment"
    android:name="com.classflow.ui.classlist.ClassListFragment"
    android:label="My Classes"
    tools:layout="@layout/fragment_class_list" >

    <action
        android:id="@+id/action_classListFragment_to_addClassFragment"
        app:destination="@id/addClassFragment" />
    <action
        android:id="@+id/action_classListFragment_to_tasksFragment"
        app:destination="@id/tasksFragment" />

</fragment>
<fragment
    android:id="@+id/addClassFragment"
    android:name="com.classflow.ui.addclass.AddClassFragment"
    android:label="Add Class"
    tools:layout="@layout/fragment_add_class" />
<fragment
    android:id="@+id/tasksFragment"
    android:name="com.classflow.ui.tasks.TasksFragment"
    android:label="Tasks"
    tools:layout="@layout/fragment_tasks" >

    <argument
        android:name="courseId"
        app:argType="long" />
    <argument
        android:name="courseName"
        app:argType="string" />

    <action
        android:id="@+id/action_tasksFragment_to_addTaskFragment"
        app:destination="@id/addTaskFragment" />
    <action
        android:id="@+id/action_tasksFragment_to_taskDetailFragment"
        app:destination="@id/taskDetailFragment" />
    <action
        android:id="@+id/action_tasksFragment_to_syllabusSetupFragment"
        app:destination="@id/syllabusSetupFragment" />

</fragment>
<fragment
    android:id="@+id/addTaskFragment"
    android:name="com.classflow.ui.tasks.AddTaskFragment"
    android:label="Add Task"
    tools:layout="@layout/fragment_add_task" >

    <argument
        android:name="courseId"
        app:argType="long" />
    <argument
        android:name="courseName"
        app:argType="string" />

</fragment>
<fragment
    android:id="@+id/taskDetailFragment"
    android:name="com.classflow.ui.tasks.TaskDetailFragment"
    android:label="Task Detail"
    tools:layout="@layout/fragment_task_detail" >

    <argument
        android:name="taskId"
        app:argType="long" />
    <argument
        android:name="courseName"
        app:argType="string" />

</fragment>
<fragment
    android:id="@+id/settingsFragment"
    android:name="com.classflow.ui.settings.SettingsFragment"
    android:label="Settings"
    tools:layout="@layout/fragment_settings" >

    <action
        android:id="@+id/action_settingsFragment_to_devToolsFragment"
        app:destination="@id/devToolsFragment" />

</fragment>
<fragment
    android:id="@+id/devToolsFragment"
    android:name="com.classflow.ui.settings.DevToolsFragment"
    android:label="Developer Tools"
    tools:layout="@layout/fragment_dev_tools" />
<fragment
    android:id="@+id/syllabusSetupFragment"
    android:name="com.classflow.ui.syllabus.SyllabusSetupFragment"
    android:label="Syllabus Task Setup"
    tools:layout="@layout/fragment_syllabus_setup" >

    <argument
        android:name="courseId"
        app:argType="long" />
    <argument
        android:name="courseName"
        app:argType="string" />

    <action
        android:id="@+id/action_syllabusSetupFragment_to_syllabusReviewFragment"
        app:destination="@id/syllabusReviewFragment" />
    <action
        android:id="@+id/action_syllabusSetupFragment_to_moduleTemplateFragment"
        app:destination="@id/moduleTemplateFragment" />

</fragment>
<fragment
    android:id="@+id/moduleTemplateFragment"
    android:name="com.classflow.ui.syllabus.ModuleTemplateFragment"
    android:label="Module Builder"
    tools:layout="@layout/fragment_module_template" />
<fragment
    android:id="@+id/syllabusReviewFragment"
    android:name="com.classflow.ui.syllabus.SyllabusReviewFragment"
    android:label="Review Syllabus Tasks"
    tools:layout="@layout/fragment_syllabus_review" />
<fragment
    android:id="@+id/ganttChartFragment"
    android:name="com.classflow.ui.timeline.TimelineContainerFragment"
    android:label="Timeline"
    tools:layout="@layout/fragment_timeline_container" >

    <action
        android:id="@+id/action_ganttChartFragment_to_taskDetailFragment"
        app:destination="@id/taskDetailFragment" />

</fragment>
<fragment
    android:id="@+id/searchTasksFragment"
    android:name="com.classflow.ui.search.SearchTasksFragment"
    android:label="Search Tasks"
    tools:layout="@layout/fragment_search_tasks" >

    <action
        android:id="@+id/action_searchTasksFragment_to_taskDetailFragment"
        app:destination="@id/taskDetailFragment" />

</fragment>
</navigation>